<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="MauiAppMain.MainPage"
             Shell.NavBarIsVisible="false">

    <Grid>
        <maps:Map
            x:Name="MyMap"
            IsVisible="False"
            IsShowingUser="True"
            MapType="Street" />

        <VerticalStackLayout
                Padding="30,0"
                Spacing="25">

                <Label x:Name="DistanceLabel" />
                <Label x:Name="GeofenceLabel" Text="Outside geofence" />

                <Label
                x:Name="PoiStatusLabel"
                Text="POI status: waiting..."
                FontSize="18"
                TextColor="Green" />
            </VerticalStackLayout>
        </Grid>

</ContentPage>
