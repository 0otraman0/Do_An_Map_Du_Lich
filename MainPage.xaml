<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="MauiAppMain.MainPage"
             Shell.NavBarIsVisible="false">

    <Grid>

        <!-- MAP -->
        <maps:Map x:Name="MyMap"
                  IsVisible="False"
                  IsShowingUser="True"
                  MapClicked="OnMapClicked" />


        <!-- TOP OVERLAY -->
        <Grid VerticalOptions="Start"
      Padding="15,10"
      RowDefinitions="Auto,Auto">

            <!-- SEARCH BAR -->
            <Frame
        Grid.Row="0"
        HeightRequest="56"
        CornerRadius="28"
        BackgroundColor="White"
        HasShadow="True"
        Padding="15,0">
                <Grid ColumnDefinitions="Auto,*,Auto"
              VerticalOptions="Center">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSearchTapped"/>
                    </Grid.GestureRecognizers>

                    <!-- Menu -->
                    <ImageButton
                Source="menu_2.svg"
                BackgroundColor="Transparent"
                WidthRequest="20"
                HeightRequest="20"
                VerticalOptions="Center"
                Clicked="OnMenuClicked"/>

                    <!-- Search -->
                    <Grid             Grid.Column="1"
>

                        <Label
            Text="{Binding Search_placeholder}"
            x:Name="SearchEntry"
            TextColor="#999999"
            FontSize="20"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            InputTransparent="True"
            Margin="0,0,0,0"/>
                    </Grid>
                    <!--TextChanged="OnSearchTextChanged"-->
                    <!-- Search Icon -->
                    <ImageButton
                Grid.Column="2"
                Source="search_svg.png"
                WidthRequest="18"
                HeightRequest="18"/>
                </Grid>

            </Frame>
        </Grid>

        <!-- TAB BAR -->
        <Border x:Name="MainTabBar"
                VerticalOptions="End"
                HeightRequest="75"
                BackgroundColor="White">

            <Grid ColumnDefinitions="*,*">

                <!-- FAVORITE -->
                <VerticalStackLayout Grid.Column="0"
                                     Spacing="5"
                                     VerticalOptions="Center">
                    <Image Source="heart_icon.png" WidthRequest="24"/>
                    <Label x:Name="Favorite_Poi_button"
                           Text="Poi yêu thích"
                           HorizontalOptions="Center"
                           FontSize="12"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFavoriteTabClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <!-- ALL -->
                <VerticalStackLayout Grid.Column="1"
                                     Spacing="5"
                                     VerticalOptions="Center">
                    <Image Source="list_icon.png" WidthRequest="24"/>
                    <Label x:Name="All_Poi_button"
                        Text="Tất cả Poi"
                           HorizontalOptions="Center"
                           FontSize="12"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAllPoiTabClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

            </Grid>
        </Border>

        <!-- BOTTOM SHEET -->
        <Grid x:Name="PoiSheet"
              BackgroundColor="White"
              Padding="20,10,20,20">

            <Grid.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnSheetPanUpdated"/>
            </Grid.GestureRecognizers>

            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HANDLE -->
            <BoxView HeightRequest="5"
                     WidthRequest="50"
                     HorizontalOptions="Center"
                     Color="Gray"/>

            <!-- CONTENT -->
            <Grid Grid.Row="1">

                <!-- SINGLE POI -->
                <VerticalStackLayout x:Name="SinglePoiView">
                    <Label Text="{Binding SelectedPoi.Name}"
                           FontSize="22"
                           FontAttributes="Bold"/>

                    <Label Text="{Binding SelectedPoi.Description}"
                           FontSize="14"/>

                    <CollectionView ItemsSource="{Binding SelectedPoi.ImageList}"
                HeightRequest="200"
                SelectionMode="None">

                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal"
                           ItemSpacing="10"/>
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame CornerRadius="10"
                   Padding="0"
                   WidthRequest="180"
                   IsClippedToBounds="True">

                                    <!-- 🔥 IMPORTANT FIX -->
                                    <Image Aspect="AspectFill">
                                        <Image.Source>
                                            <FileImageSource File="{Binding}" />
                                        </Image.Source>
                                    </Image>

                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                    <!-- AUDIO -->
                    <Frame BackgroundColor="#F1F3F4"
                           CornerRadius="30"
                           Padding="10"
                           Margin="0,10">

                        <Grid ColumnDefinitions="Auto,*,Auto">

                            <ImageButton x:Name="AudioIconBtn"
                                         Source="play_icon.png"
                                         Clicked="OnAudioToggleClicked"/>

                            <Label x:Name="AudioStatusLabel"
                                   Grid.Column="1"
                                   Text="PHÁT AUDIO"
                                   VerticalOptions="Center"/>

                        </Grid>
                    </Frame>

                </VerticalStackLayout>

                <!-- LIST -->
                <VerticalStackLayout x:Name="PoiListContainer"
                                     IsVisible="False">

                    <CollectionView x:Name="PoiListView"
                                    SelectionChanged="OnPoiItemSelected">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>

                                <VerticalStackLayout Padding="10">
                                    <!--imglist-->
                                    <CollectionView ItemsSource="{Binding ImageList}" HeightRequest="150">
                                        <CollectionView.ItemsLayout>
                                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                                        </CollectionView.ItemsLayout>
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Frame CornerRadius="12" Padding="0" IsClippedToBounds="True" WidthRequest="220" HasShadow="False">
                                                    <Image Source="{Binding}" Aspect="AspectFill" HeightRequest="150"/>
                                                </Frame>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                    <!-- name -->
                                    <Label Text="{Binding Name}"
                                           FontAttributes="Bold"/>
                                    <!-- mo ta-->
                                    <Label Text="{Binding Description}"
                                           FontSize="12"/>

                                    <Button Text="❤️"
                                            Background="Aquamarine"
                                            CommandParameter="{Binding .}"
                                            Clicked="OnFavoriteToggleClicked"/>

                                </VerticalStackLayout>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>

            </Grid>
        </Grid>

    </Grid>
</ContentPage>