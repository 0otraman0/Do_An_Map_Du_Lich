<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="MauiAppMain.MainPage"
             Shell.NavBarIsVisible="false">

    <Grid>
        <!-- MAP VIEW -->
        <maps:Map
            x:Name="MyMap"
            IsVisible="False"
            IsShowingUser="True"
            MapType="Street" />

        <!-- BOTTOM SHEET -->
        <Grid
            x:Name="PoiSheet"
            BackgroundColor="White"
            HeightRequest="300"
            VerticalOptions="End"
            TranslationY="300"
            Padding="20">
            <Grid.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnSheetPanUpdated"/>
            </Grid.GestureRecognizers>

                <!-- 👇 ONLY CHANGE IS HERE -->
                <VerticalStackLayout
                x:Name="PoiContent"
                Opacity="0"
                TranslationY="10"
                Spacing="10">
                              

                    <BoxView
                    HeightRequest="5"
                    WidthRequest="40"
                    HorizontalOptions="Center"
                    CornerRadius="3"
                    Color="Gray" />

                <Label
                    Text="{Binding SelectedPoi.Name}"
                    FontSize="20"
                    FontAttributes="Bold" />

                <Label
                    Text="{Binding SelectedPoi.Description}"
                    FontSize="14" />

            </VerticalStackLayout>

        </Grid>
        
    </Grid>
</ContentPage>
