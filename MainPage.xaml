<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="MauiAppMain.MainPage"
             Shell.NavBarIsVisible="false">

    <Grid>

        <!-- MAP -->
        <maps:Map x:Name="MyMap"
                  IsVisible="False"
                  IsShowingUser="True"
                  MapClicked="OnMapClicked" />

        <!-- TOP OVERLAY -->
        <Grid VerticalOptions="Start" Padding="15,10" RowDefinitions="Auto,Auto">
            <Frame Grid.Row="0"
                   HeightRequest="56"
                   CornerRadius="28"
                   BackgroundColor="White"
                   HasShadow="True"
                   Padding="15,0">
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSearchTapped"/>
                    </Grid.GestureRecognizers>

                    <!-- Menu -->
                    <ImageButton Source="menu_2.svg"
                                 BackgroundColor="Transparent"
                                 WidthRequest="20"
                                 HeightRequest="20"
                                 VerticalOptions="Center"
                                 Clicked="OnMenuClicked"/>

                    <!-- Search -->
                    <Grid Grid.Column="1">
                        <Label Text="{Binding Search_placeholder}"
                               x:Name="SearchEntry"
                               TextColor="#999999"
                               FontSize="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               InputTransparent="True"/>
                    </Grid>

                    <!-- Search Icon -->
                    <ImageButton Grid.Column="2"
                                 Source="search_svg.png"
                                 WidthRequest="18"
                                 HeightRequest="18"/>
                </Grid>
            </Frame>
        </Grid>

        <!-- TAB BAR -->
        <Border x:Name="MainTabBar"
                VerticalOptions="End"
                HeightRequest="75"
                BackgroundColor="White">
            <Grid ColumnDefinitions="*,*">
                <!-- FAVORITE -->
                <VerticalStackLayout Grid.Column="0" Spacing="5" VerticalOptions="Center">
                    <Image Source="heart_icon.png" WidthRequest="24"/>
                    <Label Text="Poi yêu thích"
                           HorizontalOptions="Center"
                           FontSize="12"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFavoriteTabClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <!-- ALL -->
                <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                    <Image Source="list_icon.png" WidthRequest="24"/>
                    <Label Text="Tất cả Poi"
                           HorizontalOptions="Center"
                           FontSize="12"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAllPoiTabClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- BOTTOM SHEET -->
        <Grid x:Name="PoiSheet"
              BackgroundColor="White"
              Padding="20,10,20,20">
            <Grid.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnSheetPanUpdated"/>
            </Grid.GestureRecognizers>

            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Handle -->
            <BoxView Grid.Row="0"
                     HeightRequest="5"
                     WidthRequest="50"
                     HorizontalOptions="Center"
                     Color="Gray"/>

            <!-- CONTENT -->
            <Grid Grid.Row="1">

                <!-- SINGLE POI VIEW -->
                <VerticalStackLayout x:Name="SinglePoiView"
                                     Spacing="5"
                                     IsVisible="True">

                    <Label x:Name="SingleTabTitleLabel"
                           FontAttributes="Bold"
                           FontSize="20"
                           TextColor="Black"/>

                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center" Margin="0,5">
                        <Label Text="{Binding SelectedPoi.Name}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="Black"
                               VerticalOptions="Center"/>
                        <Button x:Name="SaveBtn"
                                Grid.Column="1"
                                BackgroundColor="#F0F0F0"
                                CornerRadius="20"
                                HeightRequest="40"
                                Padding="15,0"
                                Clicked="OnSaveClicked"
                                VerticalOptions="Center">
                        </Button>
                    </Grid>

                    <Label Text="{Binding SelectedPoi.Description}"
                           FontSize="15"
                           TextColor="#444444"
                           Margin="0,0,0,10"/>

                    <!-- Audio -->
                    <Frame BackgroundColor="#F1F3F4"
                           CornerRadius="30"
                           Padding="15,10"
                           Margin="0,10">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                            <ImageButton x:Name="AudioIconBtn"
                                         Source="play_icon.png"
                                         BackgroundColor="#00AEEF"
                                         WidthRequest="45"
                                         HeightRequest="45"
                                         CornerRadius="22"
                                         Clicked="OnAudioToggleClicked"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                <Label x:Name="AudioStatusLabel"
                                       Text="PHÁT AUDIO"
                                       FontAttributes="Bold"
                                       FontSize="13"
                                       TextColor="#005670"/>
                                <Grid HeightRequest="4">
                                    <BoxView BackgroundColor="#D6D6D6" CornerRadius="2" HorizontalOptions="FillAndExpand"/>
                                    <BoxView x:Name="AudioProgressBar"
                                             BackgroundColor="#00AEEF"
                                             CornerRadius="2"
                                             HorizontalOptions="FillAndExpand"
                                             ScaleX="0"
                                             AnchorX="0"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>

                    <!-- Images -->
                    <CollectionView ItemsSource="{Binding SelectedPoi.ImageList}"
                                    HeightRequest="220"
                                    HorizontalScrollBarVisibility="Never">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame CornerRadius="10" Padding="0" IsClippedToBounds="True"
                                       WidthRequest="300" HasShadow="False">
                                    <Image Source="{Binding}" Aspect="AspectFill" HeightRequest="220"/>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- POI LIST CONTAINER (chỉ 1 CollectionView) -->
               
            </Grid>
        </Grid>
    </Grid>
</ContentPage>