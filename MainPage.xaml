<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps" x:Class="MauiAppMain.MainPage" Shell.NavBarIsVisible="false">
    <Grid>
        
        <!-- MAP VIEW -->
        <maps:Map x:Name="MyMap" IsShowingUser="True" MapClicked="OnMapClicked" MapType="Street" IsZoomEnabled="True"/>
        
        <!-- 🔵 TOP BAR OVERLAY -->
        <Grid VerticalOptions="Start" Padding="15,10" InputTransparent="False">
            <Frame HeightRequest="56" CornerRadius="28" BackgroundColor="White" HasShadow="True" Padding="15,0">
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                    
                    <!-- ☰ Menu -->
                    <ImageButton Source="menu_2.svg" BackgroundColor="Transparent" WidthRequest="10" HeightRequest="10" VerticalOptions="Center" HorizontalOptions="Start" Clicked="OnMenuClicked"/>
                    
                    <!-- Title -->
                    <Label Grid.Column="1" Text="" FontSize="20" FontAttributes="Bold" TextColor="#222222" VerticalOptions="Center" HorizontalOptions="Center" />
                    
                    <!-- Real Search Input -->
                    <Entry Grid.Column="1" Placeholder="Tìm kiếm quán ăn" BackgroundColor="Transparent" VerticalOptions="Center" HorizontalOptions="End" FontSize="20" Margin="0,0,0,5" ReturnType="Search"/>
                    
                    <!-- 🔍 Search -->
                    <ImageButton Grid.Column="2" Source="search_svg.png" WidthRequest="12" HeightRequest="12" VerticalOptions="Center" Margin="0,0,0,8" Opacity="1"/>
                </Grid>
            </Frame>
        </Grid>
       
        <!--Tab Bar-->
        <Border x:Name="MainTabBar" VerticalOptions="End" HeightRequest="75" BackgroundColor="White" StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10,10,0,0" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*, *">
                <VerticalStackLayout Grid.Column="0" Spacing="5" VerticalOptions="Center">
                    <Image x:Name="ImgFavorite" Source="heart_icon.png" WidthRequest="24" HeightRequest="24" />
                    <Label x:Name="LblFavorite" Text="Yêu thích" HorizontalOptions="Center" FontSize="12" TextColor="#5F6368" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFavoriteTabClicked" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                    <Image x:Name="ImgAll" Source="list_icon.png" WidthRequest="24" HeightRequest="24" />
                    <Label x:Name="LblAll" Text="Tất cả POI" HorizontalOptions="Center" FontSize="12" TextColor="#5F6368" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAllPoiTabClicked" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>
            </Grid>
        </Border>
        
        <!-- BOTTOM SHEET -->
        <Grid x:Name="PoiSheet" BackgroundColor="White" Padding="20,10,20,20">
            <Grid.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnSheetPanUpdated"/>
            </Grid.GestureRecognizers>
            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                
                <!-- drag handle -->
                <RowDefinition Height="*"/>
                
                <!-- content -->
            </Grid.RowDefinitions>
            <Grid HeightRequest="40">
                <BoxView HeightRequest="5" WidthRequest="50" HorizontalOptions="Center" CornerRadius="3" Color="Gray" Margin="0,0,0,5" />
            </Grid>
            <Grid Grid.Row="1" x:Name="PoiContent" Opacity="1" TranslationY="0" Margin="0,0,0,75">
                <VerticalStackLayout x:Name="SinglePoiView" IsVisible="True">
                    <Label x:Name="SingleTabTitleLabel" FontAttributes="Bold"/>
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        
                        <!-- Tên POI (bên trái) -->
                        <Label Text="{Binding SelectedPoi.Name}" FontSize="22" FontAttributes="Bold" TextColor="Black" VerticalOptions="Center"/>
                        
                        <!-- Nút Save (bên phải) -->
                        <Button x:Name="SaveBtn" Grid.Column="1" BackgroundColor="#F0F0F0" TextColor="Black" CornerRadius="20" HeightRequest="40" Padding="15,0" FontSize="13" Clicked="OnSaveClicked" VerticalOptions="Center">
                            <Button.ImageSource>
                                <FontImageSource Glyph="🤍" Size="20" Color="Gray"/>
                            </Button.ImageSource>
                        </Button>
                    </Grid>
                    <Label Text="{Binding SelectedPoi.Description}" FontSize="15" TextColor="#444444" />
                    
                    <!-- 🔊 AUDIO BAR (THÊM Ở ĐÂY) -->
                    <Frame BackgroundColor="#F1F3F4"
                           CornerRadius="30"
                           HasShadow="False"
                           Padding="15,10"
                           Margin="0,15">

                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">

                            <!-- Nút Start/Pause -->
                            <ImageButton x:Name="AudioIconBtn"
                                         Source="play_icon.png"
                                         BackgroundColor="#00AEEF"
                                         WidthRequest="45"
                                         HeightRequest="45"
                                         CornerRadius="22"
                                         Padding="12"
                                         Clicked="OnAudioToggleClicked"/>

                            <!-- Thông tin và Progress -->
                            <VerticalStackLayout Grid.Column="1"
                             VerticalOptions="Center"
                             Spacing="5">

                                <Label x:Name="AudioStatusLabel"
                                       Text="PHÁT AUDIO"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#005670" />

                                <Grid x:Name="ProgressContainer" HeightRequest="4">

                                    <!-- Thanh nền -->
                                    <BoxView BackgroundColor="#D6D6D6"
                                             CornerRadius="2"
                                             HorizontalOptions="FillAndExpand" />

                                    <!-- Thanh chạy -->
                                    <BoxView x:Name="AudioProgressBar"
                                             BackgroundColor="#00AEEF"
                                             CornerRadius="2"
                                             HorizontalOptions="FillAndExpand"
                                             ScaleX="0"
                                             AnchorX="0" />
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>

                    <CollectionView ItemsSource="{Binding SelectedPoi.ImageList}" HeightRequest="200" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame CornerRadius="10" Padding="0" IsClippedToBounds="True" WidthRequest="180">
                                    <Image Source="{Binding}" Aspect="AspectFill" HeightRequest="200"/>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <IndicatorView x:Name="indicatorView" HorizontalOptions="Center" IndicatorColor="LightGray" SelectedIndicatorColor="DeepSkyBlue" />
                </VerticalStackLayout>
                <VerticalStackLayout x:Name="PoiListContainer" IsVisible="False" Spacing="5">

                    <!-- Header hiện tên tab -->
                    <Label x:Name="CurrentTabLabel"
           Text="Tất cả POI"
           FontSize="20"
           FontAttributes="Bold"
           TextColor="Black"
           Padding="10,0"/>

                    <CollectionView x:Name="PoiListView" SelectionMode="Single" SelectionChanged="OnPoiItemSelected" VerticalOptions="FillAndExpand">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Padding="0,15" Spacing="10">
                                    <CollectionView ItemsSource="{Binding ImageList}" HeightRequest="150">
                                        <CollectionView.ItemsLayout>
                                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                                        </CollectionView.ItemsLayout>
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Frame CornerRadius="12" Padding="0" IsClippedToBounds="True" WidthRequest="220" HasShadow="False">
                                                    <Image Source="{Binding}" Aspect="AspectFill" HeightRequest="150"/>
                                                </Frame>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                    <Grid ColumnDefinitions="*, Auto" Padding="5,0">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Grid ColumnDefinitions="*, Auto" Padding="5,0">
                                               
                                                <!-- Tên POI -->
                                                    <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="Black" VerticalOptions="Center" Grid.Column="0" />
                                                    <!-- Nút Heart -->
                                                <Button Grid.Column="1" Clicked="OnFavoriteToggleClicked" CommandParameter="{Binding .}" BackgroundColor="Transparent" WidthRequest="50" HeightRequest="50" VerticalOptions="Center">
                                                    <Button.ImageSource>
                                                        <FontImageSource FontFamily="MaterialIcons" Glyph="🤍" Color="Gray" Size="30"/>
                                                    </Button.ImageSource>
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Style.Triggers>
                                                                <DataTrigger TargetType="Button" Binding="{Binding IsFavorite}" Value="True">
                                                                    <Setter Property="ImageSource">
                                                                        <Setter.Value>
                                                                            <FontImageSource Glyph="❤️" Color="DeepSkyBlue" Size="30"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                                <DataTrigger TargetType="Button" Binding="{Binding IsFavorite}" Value="False">
                                                                    <Setter Property="ImageSource">
                                                                        <Setter.Value>
                                                                            <FontImageSource Glyph="🤍" Color="Gray" Size="30"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                            <Label Text="{Binding Description}" FontSize="14" TextColor="Gray" MaxLines="2" />
                                        </VerticalStackLayout>
                                        <ImageButton Grid.Column="1" Source="{Binding IsFavorite, Converter={StaticResource FavoriteIconConverter}}" CommandParameter="{Binding .}" Clicked="OnFavoriteToggleClicked" WidthRequest="35" HeightRequest="35" VerticalOptions="Start" />
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,10,0,0"/>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>